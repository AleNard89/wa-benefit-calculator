# ==============================================================
# Orbita — Configurazione PRODUZIONE
# ==============================================================
# 1. Copia questo file in .env.prod
# 2. Compila TUTTI i campi (nessun placeholder deve rimanere)
# 3. NON committare mai .env.prod su git
# ==============================================================

PROJECT_NAME=orbita

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=orbita_user
POSTGRES_PASSWORD=CAMBIA_CON_PASSWORD_SICURA
POSTGRES_DB=orbita
PGDATA=/var/lib/postgresql/data/pgdata

# URL completo per le migrations (deve combaciare con i valori sopra)
POSTGRESQL_URL=postgres://orbita_user:CAMBIA_CON_PASSWORD_SICURA@postgres:5432/orbita?sslmode=disable

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USE_TLS=false

# --- API ---
API_SETTINGS=settings.prod.json

# --- Sicurezza (OBBLIGATORIO: usa valori lunghi e casuali) ---
# Genera con: openssl rand -base64 64
JWT_SECRET=CAMBIA_CON_STRINGA_CASUALE_LUNGA_64+_CARATTERI
# Deve essere esattamente 32 caratteri (AES-256)
ENCRYPTION_KEY=CAMBIA_CON_32_CARATTERI_ESATTI_QUI

# --- Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2025-01-01-preview
