PROJECT_NAME=benefit-calculator

# --- PostgreSQL ---
POSTGRES_HOST="postgres"
POSTGRES_PORT=5432
POSTGRES_USER="benefit_user"
POSTGRES_PASSWORD="changeme"
POSTGRES_DB="benefit_calculator"
PGDATA="/var/lib/postgresql/data/pgdata"
# POSTGRESQL_URL: compose it from USER:PASSWORD@HOST:PORT/DB above. See README for details.
POSTGRESQL_URL=xxxxxxxx

# --- Redis ---
REDIS_HOST="redis"
REDIS_PORT=6379
REDIS_USE_TLS="false"

# --- API ---
API_SETTINGS=settings.dev.json

# --- Security (change in production!) ---
JWT_SECRET="placeholder"
ENCRYPTION_KEY="placeholder"

# --- Azure OpenAI (required for chat functionality) ---
AZURE_OPENAI_ENDPOINT="https://your-resource.cognitiveservices.azure.com"
AZURE_OPENAI_API_KEY="your-api-key"
AZURE_OPENAI_CHAT_DEPLOYMENT="gpt-4.1"
AZURE_OPENAI_EMBEDDING_DEPLOYMENT="text-embedding-3-small"
AZURE_OPENAI_API_VERSION="2025-01-01-preview"

# --- Default admin credentials (seeded by migration) ---
# Email: admin@example.com
# Password: Admin123!

# --- Frontend (Vite) ---
VITE_DEV=1
VITE_APP_NAME='benefit-calculator'
VITE_LOGGER_LEVEL='TRACE'
VITE_APP_STORAGE=localStorage
VITE_API_BASE_PATH=http://localhost:8082/api
VITE_WS_BASE_PATH=http://localhost:8082/api/ws
